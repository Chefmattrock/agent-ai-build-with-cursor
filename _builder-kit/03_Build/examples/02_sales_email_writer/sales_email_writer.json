  {
    "id": "se000001-0001-0001-0001-000000000009",
    "type": "serverless_function",
    "label": "Scrape URL Content",
    "order": 8,
    "inputs": [
      {
        "name": "language",
        "value": "python",
        "type": "dropdown",
        "required": true
      },
      {
        "name": "code",
        "value": "import requests\nfrom bs4 import BeautifulSoup\n\nurl = '{{current_url}}'\ntry:\n    response = requests.get(url, timeout=10)\n    soup = BeautifulSoup(response.content, 'html.parser')\n    for script in soup(['script', 'style']):\n        script.decompose()\n    text = soup.get_text(separator=' ', strip=True)\n    result = text[:5000]\nexcept:\n    result = 'Could not fetch content'",
        "type": "textarea",
        "required": true
      },
      {
        "name": "output_variable_name",
        "value": "scraped_content",
        "type": "text",
        "required": true
      }
    ]
  },
